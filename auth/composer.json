{
    "name": "stmarkreformed/auth",
    "version": "dev-stmarkreformed_auth",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-redis": "*",
        "ext-sodium": "*",
        "buzzingpixel/minify-middleware": "^1.1",
        "buzzingpixel/php-template-engine": "^1.0",
        "composer/class-map-generator": "^1.6",
        "lcobucci/clock": "^3.3",
        "league/oauth2-server": "^9.2",
        "monolog/monolog": "^3.5",
        "psr/log": "^3.0",
        "robmorgan/phinx": "^0.16.11",
        "rxante/oauth": "^1.6",
        "rxante/php-app-bootstrap": "^1.0",
        "slim/csrf": "^1.5",
        "slim/flash": "^0.4.0",
        "symfony/cache": "^7.0"
    },
    "require-dev": {
        "buzzingpixel/symfony-var-dumper-decorator": "^1.0",
        "filp/whoops": "^2.18.0",
        "rxante/coding-standards": "^2.0",
        "symfony/var-dumper": "^6.4.18"
    },
    "autoload": {
        "psr-4": {
            "Config\\": "config",
            "App\\": "src"
        }
    },
    "config": {
        "bin-compat": "full",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}

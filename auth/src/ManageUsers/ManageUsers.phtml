<?php

use App\Html\HtmlPath;
use App\ManageUsers\ManageUsersFlashMessageCollection;
use App\User\User;
use App\User\Users;
use BuzzingPixel\Templating\TemplateEngine;

assert($this instanceof TemplateEngine);

/** @noinspection PhpUndefinedVariableInspection */
/** @var Users $users */
$users = $users ?? new Users();

/** @var ManageUsersFlashMessageCollection|null $successMessages */
$successMessages = $successMessages ?? null;

/** @var ManageUsersFlashMessageCollection|null $errorMessages */
$errorMessages = $errorMessages ?? null;

$createUrl = $createUrl ?? '/manage-users/create';
$baseUrl   = $baseUrl ?? '/manage-users';

$csrfTokenNameKey  = $csrfTokenNameKey ?? '';
$csrfTokenName     = $csrfTokenName ?? '';
$csrfTokenValueKey = $csrfTokenValueKey ?? '';
$csrfTokenValue    = $csrfTokenValue ?? '';

global $wrapperWidth;
$wrapperWidth = 'max-w-4xl';
$this->extends(HtmlPath::CENTERED_WRAPPER_LAYOUT);
?>

<div class="text-left">
    <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold tracking-tight text-bronze-lightened-1">
            Manage Users
        </h2>
        <a
            href="<?=$this->html($createUrl)?>"
            class="rounded-lg bg-crimson hover:bg-crimson-dark px-3.5 py-3 text-sm font-semibold text-white shadow-xs"
        >
            Create user
        </a>
    </div>

    <?php if ($successMessages?->hasMessages()): ?>
        <div class="rounded-lg border border-green-600 bg-green-50 px-5 py-4 text-sm font-medium text-green-800 mb-6">
            <?php foreach ($successMessages->messages as $message): ?>
                <div><?= $this->html($message->title) ?></div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>

    <?php if ($errorMessages?->hasMessages()): ?>
        <div class="rounded-lg bg-red-50 px-5 py-4 text-sm text-red-700 mb-6">
            <ul class="space-y-1">
                <?php foreach ($errorMessages->messages as $message): ?>
                    <li><?= $this->html($message->title) ?></li>
                <?php endforeach; ?>
            </ul>
        </div>
    <?php endif; ?>

    <?php if (! $users->hasUsers()): ?>
        <p class="text-sm text-rx-gray-500">No users yet.</p>
    <?php else: ?>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
            <table class="min-w-full divide-y divide-gray-200 text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-left font-semibold text-rx-gray-500">
                            Email
                        </th>
                        <th class="px-4 py-3 text-left font-semibold text-rx-gray-500">
                            Roles
                        </th>
                        <th class="px-4 py-3 text-right font-semibold text-rx-gray-500">
                            Actions
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 bg-white">
                    <?php foreach ($users->users as $user): ?>
                        <?php assert($user instanceof User); ?>
                        <?php $id = $user->id->toString(); ?>
                        <tr>
                            <td class="px-4 py-3 align-top">
                                <a
                                    href="<?=$this->html($baseUrl . '/' . $id . '/edit')?>"
                                    class="font-medium text-rx-light-blue-500 hover:text-rx-light-blue-300 hover:underline"
                                >
                                    <?= $this->html($user->email->toString()) ?>
                                </a>
                            </td>
                            <td class="px-4 py-3 align-top text-rx-gray-500">
                                <?php if ($user->roles->count() < 1): ?>
                                    <span class="text-gray-400">—</span>
                                <?php else: ?>
                                    <?php foreach ($user->roles->asArray() as $role): ?>
                                        <div><?= $this->html($role) ?></div>
                                    <?php endforeach; ?>
                                <?php endif; ?>
                            </td>
                            <td class="px-4 py-3 align-top">
                                <div class="flex flex-wrap items-center justify-end gap-2">
                                    <a
                                        href="<?=$this->html($baseUrl . '/' . $id . '/edit')?>"
                                        class="rounded-md bg-rx-light-blue-500 hover:bg-rx-light-blue-300 px-3 py-1.5 text-xs font-semibold text-white"
                                    >
                                        Edit
                                    </a>
                                    <a
                                        href="<?=$this->html($baseUrl . '/' . $id . '/password')?>"
                                        class="rounded-md bg-saddle-brown hover:bg-saddle-brown-lightened-2 px-3 py-1.5 text-xs font-semibold text-white"
                                    >
                                        Reset password
                                    </a>
                                    <form
                                        method="POST"
                                        action="<?=$this->html($baseUrl . '/' . $id . '/delete')?>"
                                        onsubmit="return confirm('Delete this user? This cannot be undone.');"
                                    >
                                        <input
                                            type="hidden"
                                            name="<?= $csrfTokenNameKey ?>"
                                            value="<?= $csrfTokenName ?>"
                                        >
                                        <input
                                            type="hidden"
                                            name="<?= $csrfTokenValueKey ?>"
                                            value="<?= $csrfTokenValue ?>"
                                        >
                                        <button
                                            type="submit"
                                            class="rounded-md bg-crimson hover:bg-crimson-dark px-3 py-1.5 text-xs font-semibold text-white cursor-pointer"
                                        >
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    <?php endif; ?>
</div>

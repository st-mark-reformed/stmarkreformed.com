# Local, non-critical, harmless "secrets" may be placed in this file

DEV_MODE=1

USE_WHOOPS_ERROR_HANDLING=1
USE_PRODUCTION_ERROR_MIDDLEWARE=0

REDIS_HOST=stmark-redis

LOG_HANDLER_FACTORIES=\App\Logging\HandlerFactories\Stderr,\App\Logging\HandlerFactories\Stdout

ENABLE_QUEUE_MANAGEMENT_ROUTES=0

AUTH_WELL_KNOWN_URL=https://auth.stmark.localtest.me/well-known/openid-configuration

# Email
SMTP_USER=dev
SMTP_PASSWORD=dev
SMTP_HOST=smrc-mailhog
SMTP_PORT=1025
SYSTEM_EMAIL_FROM_ADDRESS=hello@stmarkreformed.com
SYSTEM_EMAIL_FROM_NAME=SMRC
CONTACT_FORM_RECIPIENTS=

# API DB
SMRC_API_DB_HOST=stmark-db
SMRC_API_DB_NAME=smrc_api
SMRC_API_DB_USER=smrc_api
SMRC_API_DB_PASSWORD=MoaEvf8Keh57Icc7AXDo1ncFM0LhOM0g

## Transfer
APP_API_URL=http://stmark-app

## Search
ELASTIC_SEARCH_HOSTS=http://stmark-elasticsearch:9200
